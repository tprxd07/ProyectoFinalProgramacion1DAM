<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="550.0" prefWidth="650.0" styleClass="main-container" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalprogramacion1dam.controller.HistorialController">
    <children>

        <VBox spacing="5.0">
            <padding>
                <Insets left="25.0" right="25.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="titulo" text="Historial de Compras" />
            </children>
        </VBox>

        <HBox spacing="10.0" styleClass="contenedor-filtros-historial">
            <children>
                <Label styleClass="texto" text="Ordenar por:" />
                <ComboBox fx:id="cbOrden" onAction="#cambiarOrden" prefWidth="180.0" styleClass="boton-basico" />
            </children>
        </HBox>

        <ScrollPane hbarPolicy="NEVER" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
            </padding>
            <content>
                <VBox fx:id="listaCompras" prefWidth="580.0" spacing="12.0" />
            </content>
        </ScrollPane>

    </children>
</VBox>