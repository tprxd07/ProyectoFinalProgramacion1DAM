<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700.0" prefWidth="900.0" styleClass="main-container" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalprogramacion1dam.controller.DetalleAppController">
   <VBox prefWidth="80.0" HBox.hgrow="ALWAYS">
      <padding>
         <Insets left="20.0" top="20.0" />
      </padding>
      <Button mnemonicParsing="false" onAction="#volverAtras" styleClass="boton-icono">
         <graphic>
            <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/volver.png" />
               </image></ImageView>
         </graphic>
      </Button>
   </VBox>

   <ScrollPane fx:id="scrollPrincipal" pannable="true" styleClass="scroll-transparente" vbarPolicy="NEVER" HBox.hgrow="ALWAYS">
      <content>
         <VBox maxWidth="700.0" prefWidth="700.0" spacing="25.0">
            <padding>
               <Insets top="30.0" />
            </padding>
            <HBox spacing="25.0">
               <Pane prefHeight="160.0" prefWidth="160.0">
                  <children>
                     <ImageView fx:id="portada" fitHeight="160.0" fitWidth="160.0" pickOnBounds="true" />
                  </children>
               </Pane>
               <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                  <Label fx:id="nombre" styleClass="titulo-grande" text="Nombre de la App" />
                  <Label fx:id="desarrollador" styleClass="subtitulo" text="Desarrollador" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Label fx:id="descargas" styleClass="texto-pequeno" text="0 descargas" />
               </VBox>
               <VBox alignment="CENTER">
                  <Button fx:id="botonAdquirir" mnemonicParsing="false" onAction="#accionarBotonPrincipal" prefHeight="45.0" prefWidth="140.0" styleClass="boton-descargas" text="0.00 €" />
               </VBox>
            </HBox>

            <VBox spacing="10.0">
               <Label styleClass="subtitulo" text="Información de la aplicación" />
               <Label fx:id="descripcion" lineSpacing="5.0" styleClass="texto" text="Descripción larga..." wrapText="true" />
            </VBox>

            <VBox fx:id="nuevaResenia" spacing="15.0" styleClass="contenedor-resenia-propia">
               <Label fx:id="tituloResenia" styleClass="subtitulo" text="Valora esta aplicación" />
               <HBox alignment="CENTER_LEFT" spacing="15.0">
                  <HBox fx:id="boxEstrellas" spacing="5.0">
                     <ToggleButton fx:id="star1" styleClass="boton-estrella" text="☆" />
                     <ToggleButton fx:id="star2" styleClass="boton-estrella" text="☆" />
                     <ToggleButton fx:id="star3" styleClass="boton-estrella" text="☆" />
                     <ToggleButton fx:id="star4" styleClass="boton-estrella" text="☆" />
                     <ToggleButton fx:id="star5" styleClass="boton-estrella" text="☆" />
                  </HBox>
               </HBox>
               <VBox spacing="5.0">
                  <TextArea fx:id="comentario" prefHeight="100.0" promptText="Cuéntale a otros qué te ha parecido..." styleClass="text-area-resenia" wrapText="true" />
                  <HBox alignment="CENTER_RIGHT">
                     <Button fx:id="confirmarResenia" onAction="#enviarFormularioResenia" prefWidth="100.0" styleClass="nav-button" text="Enviar" />
                  </HBox>
               </VBox>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="separador-resenias">
               <Label styleClass="subtitulo" text="Opiniones de los usuarios" />
               <Region HBox.hgrow="ALWAYS" />
               <ComboBox fx:id="cbFiltroResenias" onAction="#filtrarResenias" prefWidth="180.0" promptText="Ordenar por" styleClass="boton-basico" />
            </HBox>

            <VBox fx:id="contenedorResenia" spacing="15.0">
               <padding>
                  <Insets bottom="30.0" />
               </padding>
            </VBox>
         </VBox>
      </content>
   </ScrollPane>

   <Region prefWidth="80.0" HBox.hgrow="ALWAYS" />
</HBox>
