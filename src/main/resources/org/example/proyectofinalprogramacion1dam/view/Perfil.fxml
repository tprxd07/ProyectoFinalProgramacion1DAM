<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" styleClass="main-container" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalprogramacion1dam.controller.PerfilController">
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="25.0" />
    </padding>
    <children>

        <Label fx:id="labelNombreUsuario" styleClass="titulo" text="Nombre usuario" />

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label styleClass="subtitulo" text="Biblioteca" />
                <ScrollPane hbarPolicy="NEVER" styleClass="scroll-pane" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="apartadoBiblioteca" prefWidth="730.0" styleClass="contenedor-biblioteca" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <VBox alignment="CENTER">
            <children>
            <Button fx:id="cerrarSesion1" maxHeight="-Infinity" mnemonicParsing="false" onAction="#cerrarSesionActiva" prefHeight="60.0" prefWidth="160.0" styleClass="nav-button" text="Cerrar sesión">
               <font>
                  <Font size="14.0" />
               </font>
               <graphic>
                  <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/cerrarSesion.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </VBox>

    </children>
</VBox>
