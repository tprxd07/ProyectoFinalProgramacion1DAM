<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="400.0" prefWidth="600.0" styleClass="main-container" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalprogramacion1dam.controller.TiendaPrincipalController">
   <children>
      <VBox prefHeight="537.0" prefWidth="181.0">
         <children>
            <Button fx:id="botonInicio" alignment="CENTER" contentDisplay="TOP" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#menuElegido" styleClass="nav-button" text="Inicio" VBox.vgrow="ALWAYS">
               <graphic>
                  <ImageView fitHeight="46.0" fitWidth="62.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/casa.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            <Button fx:id="botonJuegos" alignment="CENTER" contentDisplay="TOP" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#menuElegido" styleClass="nav-button" text="Juegos" VBox.vgrow="ALWAYS">
               <graphic>
                  <ImageView fitHeight="55.0" fitWidth="54.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/mando.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            <Button fx:id="botonApps" alignment="CENTER" contentDisplay="TOP" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#menuElegido" styleClass="nav-button" text="Aplicaciones" VBox.vgrow="ALWAYS">
               <graphic>
                  <ImageView fitHeight="114.0" fitWidth="53.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/apps.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
      </VBox>
      <VBox prefHeight="400.0" prefWidth="511.0">
         <children>
            <HBox maxWidth="1.7976931348623157E308" prefHeight="21.0" prefWidth="466.0" VBox.vgrow="NEVER">
               <children>
                  <Region prefHeight="100.0" prefWidth="67.0" HBox.hgrow="NEVER" />
                  <TextField maxWidth="1000.0" prefHeight="26.0" prefWidth="214.0" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets top="15.0" />
                     </HBox.margin>
                  </TextField>
                  <Region prefHeight="58.0" prefWidth="67.0" HBox.hgrow="SOMETIMES" />
                  <Button fx:id="botonAjustes" graphicTextGap="0.0" mnemonicParsing="false" onAction="#menuAjustes" prefHeight="50.0" prefWidth="50.0" styleClass="boton-ajustes">
                     <graphic>
                        <ImageView fx:id="imagenEngranaje" fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/engranaje-amarillo.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </HBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefHeight="300.0" prefWidth="480.0" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="filasMain" prefHeight="342.0" prefWidth="464.0" spacing="30.0">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
      <VBox fx:id="panelAjustes" maxWidth="0.0" minWidth="0.0" prefHeight="0.0" prefWidth="0.0" visible="false">
         <children>
            <Button mnemonicParsing="false" text="Perfil" />
            <Button mnemonicParsing="false" text="Biblioteca" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
            <Button mnemonicParsing="false" text="Historial de compras" />
            <Button mnemonicParsing="false" text="Button" />
         </children>
      </VBox>
   </children>
</HBox>
