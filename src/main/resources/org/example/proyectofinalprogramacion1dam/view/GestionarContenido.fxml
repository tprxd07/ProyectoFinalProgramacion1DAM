<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="500.0" styleClass="main-container" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalprogramacion1dam.controller.GestionarContenidoController">
    <children>

        <VBox spacing="12.0">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="botonPestaniaApp" mnemonicParsing="false" onAction="#cambiarPestania" prefWidth="230.0" styleClass="nav-button" text="Aplicaciones" />
                        <Button fx:id="botonPestaniasDes" mnemonicParsing="false" onAction="#cambiarPestania" prefWidth="230.0" styleClass="nav-button" text="Desarrolladores" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="botonAniadir" mnemonicParsing="false" onAction="#cambiarAccion" prefWidth="150.0" styleClass="nav-button" text="Añadir" />
                        <Button fx:id="botonModificar" mnemonicParsing="false" onAction="#cambiarAccion" prefWidth="150.0" styleClass="nav-button" text="Modificar" />
                        <Button fx:id="botonEliminar" mnemonicParsing="false" onAction="#cambiarAccion" prefWidth="150.0" styleClass="nav-button" text="Eliminar" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox VBox.vgrow="ALWAYS" spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>

                <VBox fx:id="formAplicacion" spacing="12.0" visible="false">
                    <children>
                        <Label styleClass="titulo" text="Datos de la Aplicación" />

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Nombre de la Aplicación:" />
                            <TextField fx:id="nombreApp" styleClass="text-field" />
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <RadioButton fx:id="rbVideojuego" mnemonicParsing="false" selected="true" styleClass="texto" text="Videojuego">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="grupoTipoApp" />
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton fx:id="rbUtilidad" mnemonicParsing="false" styleClass="texto" text="Utilidad" toggleGroup="$grupoTipoApp" />

                                <HBox fx:id="contenedorMultijugador" alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="texto" text="¿Multijugador?" />
                                        <ComboBox fx:id="cbMultijugador" styleClass="boton-basico" prefWidth="75.0" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Precio (€):" />
                            <TextField fx:id="precioApp" styleClass="text-field" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Desarrollador Responsable:" />
                            <ComboBox fx:id="cbDesarrolladorApp" maxWidth="1.7976931348623157E308" styleClass="boton-basico" promptText="Selecciona un desarrollador" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Categoría:" />
                            <ComboBox fx:id="cbCategoria" maxWidth="1.7976931348623157E308" styleClass="boton-basico" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="URL de la Imagen/Icono:" />
                            <TextField fx:id="imagenApp" styleClass="text-field" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Descripción:" />
                            <TextArea fx:id="descApp" prefHeight="80.0" styleClass="text-area" wrapText="true" />
                        </VBox>
                    </children>
                </VBox>

                <VBox fx:id="formDesarrollador" spacing="12.0" visible="false">
                    <children>
                        <Label styleClass="titulo" text="Datos del Desarrollador" />

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="Nombre del Desarrollador:" />
                            <TextField fx:id="nombreDes" styleClass="text-field" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label styleClass="texto" text="País de Origen:" />
                            <TextField fx:id="paisDes" styleClass="text-field" />
                        </VBox>
                    </children>
                </VBox>

                <VBox fx:id="formEliminar" spacing="12.0" visible="false">
                    <children>
                        <Label styleClass="titulo" text="Eliminar Contenido" />
                        <Label styleClass="texto-cursivo" text="Selecciona el elemento que se borrará permanentemente de la base de datos:" />
                        <ComboBox fx:id="cbElementosBorrar" maxWidth="1.7976931348623157E308" styleClass="boton-basico" />
                    </children>
                </VBox>

                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="botonConfirmar" mnemonicParsing="false" onAction="#ejecutarOperacion" prefHeight="38.0" prefWidth="220.0" styleClass="nav-button" text="Guardar Cambios" />
                    </children>
                    <padding>
                        <Insets top="15.0" />
                    </padding>
                </VBox>

            </children>
        </VBox>
    </children>
</VBox>